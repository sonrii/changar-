# ChangAR - Environment Configuration
# Copy this file to .env.local and fill in your values

# Firebase Configuration (Required)
# Get these from Firebase Console > Project Settings > General
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# World Mini App Configuration
# Required for World Mini App integration
# Get these from World Developer Portal: https://developer.worldcoin.org/
# Leave empty to run in browser/Firebase mode only
NEXT_PUBLIC_WORLD_APP_ID=

# Optional: World API configuration
# NEXT_PUBLIC_WORLD_API_KEY=

# App Configuration
NEXT_PUBLIC_APP_NAME=ChangAR
NEXT_PUBLIC_APP_URL=https://changar.app

# Environment
NEXT_PUBLIC_ENVIRONMENT=development
