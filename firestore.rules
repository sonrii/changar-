rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isClient() {
      return isAuthenticated() && getUserData().role == 'client';
    }
    
    function isWorker() {
      return isAuthenticated() && getUserData().role == 'worker';
    }
    
    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }
    
    // Worker profiles collection
    match /worker_profiles/{profileId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(profileId) && isWorker();
      allow update: if isOwner(profileId) && isWorker();
      allow delete: if false;
    }
    
    // Job requests collection
    match /job_requests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isClient() && request.resource.data.clientUid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.clientUid == request.auth.uid;
      allow delete: if false;
    }
    
    // Applications collection
    match /applications/{applicationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isWorker() && request.resource.data.workerUid == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.workerUid == request.auth.uid ||
        get(/databases/$(database)/documents/job_requests/$(resource.data.requestId)).data.clientUid == request.auth.uid
      );
      allow delete: if false;
    }
    
    // Reviews collection
    match /reviews/{reviewId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.fromUid == request.auth.uid;
      allow update: if false;
      allow delete: if false;
    }
  }
}
